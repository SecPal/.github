#!/bin/bash
# SPDX-FileCopyrightText: 2025 SecPal Contributors
# SPDX-License-Identifier: AGPL-3.0-or-later
#
# Pre-commit hook template for all SecPal repositories
#
# Installation:
#   cp .github/templates/hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# This hook enforces Lesson #17 (Git State Verification) by:
# - Detecting whitespace errors
# - Checking code formatting (Prettier)
# - Verifying REUSE compliance
# - Catching formatter-induced changes after git add

set -e

echo "🔍 Pre-commit Hook: Running checks (Lesson #17 compliance)..."
echo ""

# 1. Check for whitespace errors
echo "📝 Checking for whitespace errors..."
if ! git diff --check --cached; then
  echo ""
  echo "❌ Whitespace errors detected!"
  echo "Fix them and try again."
  exit 1
fi
echo "✅ No whitespace errors"
echo ""

# 2. Run Prettier formatting check (if package.json has format:check script)
# Only run if relevant files are staged (performance optimization)
FORMAT_FILE_PATTERN='\.(js|ts|json|jsx|tsx|md|yml|yaml)$|^package\.json$|^package-lock\.json$'
STAGED_FORMAT_FILES=$(git diff --cached --name-only | grep -E "$FORMAT_FILE_PATTERN" || true)

# Break complex condition into readable checks
HAS_PACKAGE_JSON=false
HAS_FORMAT_CHECK=false
HAS_STAGED_FORMAT_FILES=false

if [ -f "package.json" ]; then
  HAS_PACKAGE_JSON=true
  if grep -q '"format:check"[[:space:]]*:' package.json 2>/dev/null; then
    HAS_FORMAT_CHECK=true
  fi
fi

if [ -n "$STAGED_FORMAT_FILES" ]; then
  HAS_STAGED_FORMAT_FILES=true
fi

if [ "$HAS_PACKAGE_JSON" = true ] && [ "$HAS_FORMAT_CHECK" = true ] && [ "$HAS_STAGED_FORMAT_FILES" = true ]; then
  echo "🎨 Checking code formatting (Prettier) on staged files..."
  if ! npm run format:check --silent; then
    echo ""
    echo "❌ Code formatting check failed!"
    echo ""
    echo "Files need formatting. Run:"
    echo "  npm run format"
    echo ""
    echo "Then stage the changes:"
    echo "  git add -A"
    echo ""
    exit 1
  fi
  echo "✅ All files properly formatted"
  echo ""
fi

# 3. Check REUSE compliance (if reuse tool is installed)
if command -v reuse &> /dev/null; then
  echo "📋 Checking REUSE compliance..."
  if ! reuse lint > /dev/null 2>&1; then
    echo ""
    echo "❌ REUSE compliance check failed!"
    echo ""
    echo "Run this to see details:"
    echo "  reuse lint"
    echo ""
    echo "Common fixes:"
    echo "  - Add SPDX headers to new files"
    echo "  - Download missing licenses: reuse download <license>"
    echo "  - Check REUSE.toml annotations"
    echo ""
    exit 1
  fi
  echo "✅ REUSE compliant"
  echo ""
else
  echo "⚠️  REUSE tool not installed - skipping compliance check"
  echo "   Install: pip install reuse"
  echo ""
fi

# 4. Check for unstaged changes (formatter detection)
echo "🔎 Checking for unstaged changes (formatter detection)..."
if ! git diff --quiet; then
  echo ""
  echo "⚠️  WARNING: Unstaged changes detected!"
  echo ""
  echo "This might be from formatters running after 'git add'."
  echo "Modified files:"
  git diff --name-only
  echo ""
  echo "Recommendation:"
  echo "  1. Review changes: git diff"
  echo "  2. Stage them: git add -A"
  echo "  3. Commit again"
  echo ""
  echo "❌ Blocking commit to prevent inconsistent state (Lesson #17)"
  exit 1
fi
echo "✅ No unstaged changes"
echo ""

# 5. Check documentation quality (if scripts are available)
# Only run on staged markdown files in docs/ directory
STAGED_DOCS=$(git diff --cached --name-only | grep -E '^docs/.*\.md$' || true)

if [ -n "$STAGED_DOCS" ]; then
  SCRIPTS_DIR="scripts"
  # Handle both .github repo structure and other repos referencing .github
  if [ ! -d "$SCRIPTS_DIR" ] && [ -d "../.github/scripts" ]; then
    SCRIPTS_DIR="../.github/scripts"
  fi

  if [ -f "$SCRIPTS_DIR/shellcheck-docs.sh" ]; then
    echo "🔍 Checking bash blocks in documentation..."
    FAILED_FILES=""
    for file in $STAGED_DOCS; do
      if ! "$SCRIPTS_DIR/shellcheck-docs.sh" "$file" > /dev/null 2>&1; then
        FAILED_FILES="$FAILED_FILES$file "
      fi
    done

    if [ -n "$FAILED_FILES" ]; then
      echo ""
      echo "❌ Bash block validation failed!"
      echo ""
      echo "Failed files:"
      for file in $FAILED_FILES; do
        echo "  - $file"
      done
      echo ""
      echo "Run this for details:"
      for file in $FAILED_FILES; do
        echo "  $SCRIPTS_DIR/shellcheck-docs.sh $file"
      done
      echo ""
      exit 1
    fi
    echo "✅ All bash blocks validated"
    echo ""
  fi

  if [ -f "$SCRIPTS_DIR/check-hardcoded-examples.sh" ]; then
    echo "🔍 Checking for hardcoded values in examples..."
    FAILED_FILES=""
    for file in $STAGED_DOCS; do
      if ! "$SCRIPTS_DIR/check-hardcoded-examples.sh" "$file" > /dev/null 2>&1; then
        FAILED_FILES="$FAILED_FILES$file "
      fi
    done

    if [ -n "$FAILED_FILES" ]; then
      echo ""
      echo "❌ Hardcoded value check failed!"
      echo ""
      echo "Failed files:"
      for file in $FAILED_FILES; do
        echo "  - $file"
      done
      echo ""
      echo "Run this for details:"
      for file in $FAILED_FILES; do
        echo "  $SCRIPTS_DIR/check-hardcoded-examples.sh $file"
      done
      echo ""
      exit 1
    fi
    echo "✅ No hardcoded values detected"
    echo ""
  fi

  if [ -f "$SCRIPTS_DIR/validate-graphql-docs.sh" ]; then
    echo "🔍 Validating GraphQL queries in documentation..."
    FAILED_FILES=""
    for file in $STAGED_DOCS; do
      if ! "$SCRIPTS_DIR/validate-graphql-docs.sh" "$file" > /dev/null 2>&1; then
        FAILED_FILES="$FAILED_FILES$file "
      fi
    done

    if [ -n "$FAILED_FILES" ]; then
      echo ""
      echo "❌ GraphQL validation failed!"
      echo ""
      echo "Failed files:"
      for file in $FAILED_FILES; do
        echo "  - $file"
      done
      echo ""
      echo "Run this for details:"
      for file in $FAILED_FILES; do
        echo "  $SCRIPTS_DIR/validate-graphql-docs.sh $file"
      done
      echo ""
      exit 1
    fi
    echo "✅ All GraphQL queries validated"
    echo ""
  fi
fi

echo "✅ All pre-commit checks passed!"
echo ""
exit 0
