{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/SecPal/.github/blob/main/.agents/skills/secpal-pr-review/references/fast-path-batch.schema.json",
  "$comment": "SPDX-FileCopyrightText: 2026 SecPal Contributors; SPDX-License-Identifier: CC0-1.0",
  "title": "SecPal fast PR review batch",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "batch_id",
    "repository",
    "pull_request_number",
    "expected_head_sha",
    "expected_base_ref",
    "expected_base_sha",
    "expected_actor",
    "reviewed_state_digest",
    "reviewed_feedback_digest",
    "findings",
    "operations",
    "prior_results"
  ],
  "properties": {
    "schema_version": { "const": "1.1" },
    "batch_id": { "$ref": "#/$defs/identity" },
    "repository": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    },
    "pull_request_number": { "type": "integer", "minimum": 1 },
    "expected_head_sha": { "$ref": "#/$defs/oid" },
    "expected_base_ref": { "$ref": "#/$defs/identity" },
    "expected_base_sha": { "$ref": "#/$defs/oid" },
    "expected_actor": { "$ref": "#/$defs/actor" },
    "reviewed_state_digest": { "$ref": "#/$defs/digest" },
    "reviewed_feedback_digest": { "$ref": "#/$defs/digest" },
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/finding" }
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/operation" }
    },
    "prior_results": {
      "type": "array",
      "items": { "$ref": "#/$defs/prior_result" }
    }
  },
  "$defs": {
    "identity": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^\\u0000-\\u0020\\u007f]+$"
    },
    "oid": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{40,64}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["login", "node_id", "database_id"],
      "properties": {
        "login": { "$ref": "#/$defs/identity" },
        "node_id": { "$ref": "#/$defs/identity" },
        "database_id": { "type": "integer", "minimum": 1 }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_id",
        "thread_id",
        "source_comments",
        "source_subitem_id",
        "classification",
        "disposition",
        "evidence_digest",
        "test_evidence_digest",
        "commit_sha",
        "canonical_finding_id"
      ],
      "properties": {
        "finding_id": { "$ref": "#/$defs/identity" },
        "thread_id": { "$ref": "#/$defs/identity" },
        "source_comments": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["comment_id", "body_digest"],
            "properties": {
              "comment_id": { "$ref": "#/$defs/identity" },
              "body_digest": { "$ref": "#/$defs/digest" }
            }
          }
        },
        "source_subitem_id": {
          "anyOf": [{ "$ref": "#/$defs/identity" }, { "type": "null" }]
        },
        "classification": {
          "enum": [
            "VALID_ACTIONABLE",
            "INVALID_FALSE_OR_MISLEADING",
            "INFORMATIONAL",
            "DUPLICATE",
            "OUTDATED_BUT_STILL_VALID",
            "OUTDATED_AND_OBSOLETE",
            "ALREADY_FIXED_ON_SNAPSHOT_HEAD",
            "SUPERSEDED",
            "SECURITY_WEAKENING_SUGGESTION"
          ]
        },
        "disposition": {
          "enum": [
            "CORRECTED_AND_VERIFIED",
            "PROVEN_EXISTING_FIX",
            "DISPROVEN_WITH_EVIDENCE",
            "NON_ACTIONABLE",
            "DUPLICATE_OF_CANONICAL",
            "OBSOLETE_ON_CURRENT_HEAD",
            "SUPERSEDED_BY_CANONICAL",
            "REJECTED_SECURITY_WEAKENING"
          ]
        },
        "evidence_digest": { "$ref": "#/$defs/digest" },
        "test_evidence_digest": {
          "anyOf": [{ "$ref": "#/$defs/digest" }, { "type": "null" }]
        },
        "commit_sha": {
          "anyOf": [{ "$ref": "#/$defs/oid" }, { "type": "null" }]
        },
        "canonical_finding_id": {
          "anyOf": [{ "$ref": "#/$defs/identity" }, { "type": "null" }]
        }
      }
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operation_id", "kind", "thread_id", "finding_ids"],
      "properties": {
        "operation_id": { "$ref": "#/$defs/identity" },
        "kind": { "const": "THREAD_RESOLUTION" },
        "thread_id": { "$ref": "#/$defs/identity" },
        "finding_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identity" }
        }
      }
    },
    "prior_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation_id",
        "thread_id",
        "authorization_digest",
        "mutation_identity",
        "status"
      ],
      "properties": {
        "operation_id": { "$ref": "#/$defs/identity" },
        "thread_id": { "$ref": "#/$defs/identity" },
        "authorization_digest": { "$ref": "#/$defs/digest" },
        "mutation_identity": { "$ref": "#/$defs/identity" },
        "status": { "const": "APPLIED" }
      }
    }
  }
}
