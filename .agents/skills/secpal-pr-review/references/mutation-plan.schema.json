{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/SecPal/.github/blob/main/.agents/skills/secpal-pr-review/references/mutation-plan.schema.json",
  "$comment": "SPDX-FileCopyrightText: 2026 SecPal Contributors; SPDX-License-Identifier: CC0-1.0",
  "title": "SecPal finite PR review mutation plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "repository",
    "pull_request_number",
    "snapshot_digest",
    "initial_snapshot_digest",
    "expected_head_sha",
    "created_for_state",
    "cycle_number",
    "session",
    "findings",
    "operations"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "repository": { "type": "string", "pattern": "^[^/]+/[^/]+$" },
    "pull_request_number": { "type": "integer", "minimum": 1 },
    "snapshot_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "initial_snapshot_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "expected_head_sha": { "type": "string", "pattern": "^[0-9a-fA-F]{40,64}$" },
    "created_for_state": {
      "enum": [
        "APPLY_JUSTIFIED_REACTIONS_AND_EXCEPTION_REPLIES",
        "RESOLVE_ELIGIBLE_THREADS_FROM_VERIFIED_STATE"
      ]
    },
    "cycle_number": { "type": "integer", "minimum": 0, "maximum": 2 },
    "session": { "$ref": "#/$defs/session" },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "operations": {
      "type": "array",
      "items": { "$ref": "#/$defs/operation" }
    }
  },
  "$defs": {
    "nullable_string": { "type": ["string", "null"] },
    "nullable_integer": { "type": ["integer", "null"] },
    "classification": {
      "enum": [
        "VALID_ACTIONABLE",
        "INVALID_FALSE_OR_MISLEADING",
        "AMBIGUOUS_NEEDS_USER_DECISION",
        "INFORMATIONAL",
        "DUPLICATE",
        "OUTDATED_BUT_STILL_VALID",
        "OUTDATED_AND_OBSOLETE",
        "ALREADY_FIXED_ON_SNAPSHOT_HEAD",
        "SUPERSEDED",
        "OUTSIDE_PR_SCOPE",
        "CROSS_REPOSITORY",
        "CONFLICTING_REVIEWERS",
        "SECURITY_WEAKENING_SUGGESTION"
      ]
    },
    "session": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "state_captures",
        "remediation_cycles",
        "holistic_audits",
        "signed_commits",
        "fast_forward_pushes",
        "evidence_replies",
        "reaction_writes",
        "thread_resolutions",
        "worktree_clean",
        "head_matches",
        "snapshot_digest_matches",
        "unexplained_commit",
        "signatures_valid",
        "evidence_complete",
        "ci_state",
        "unresolved_material_finding",
        "github_state_safe",
        "scope_requires_other_repository",
        "late_feedback_detected",
        "push_failed",
        "mutation_failed",
        "actionable_findings",
        "merge_ready_evidence"
      ],
      "properties": {
        "state": {
          "enum": [
            "INITIALIZE",
            "VERIFY_LOCAL_AND_PR_STATE",
            "CAPTURE_ONE_IMMUTABLE_SNAPSHOT",
            "CLASSIFY_ALL_SNAPSHOT_ITEMS",
            "APPLY_JUSTIFIED_REACTIONS_AND_EXCEPTION_REPLIES",
            "REMEDIATION_CYCLE_1",
            "LOCAL_VALIDATE_SIGN_COMMIT_FAST_FORWARD_PUSH",
            "HOLISTIC_AUDIT",
            "POST_CYCLE_1_SINGLE_GITHUB_READ",
            "OPTIONAL_REMEDIATION_CYCLE_2",
            "FINAL_SINGLE_GITHUB_READ",
            "RESOLVE_ELIGIBLE_THREADS_FROM_VERIFIED_STATE",
            "WAIT_FOR_EXPLICIT_USER_MERGE_AUTHORIZATION",
            "TERMINAL"
          ]
        },
        "state_captures": { "type": "integer", "minimum": 0, "maximum": 3 },
        "remediation_cycles": { "type": "integer", "minimum": 0, "maximum": 2 },
        "holistic_audits": { "type": "integer", "minimum": 0, "maximum": 1 },
        "signed_commits": { "type": "integer", "minimum": 0, "maximum": 2 },
        "fast_forward_pushes": { "type": "integer", "minimum": 0, "maximum": 2 },
        "evidence_replies": { "type": "integer", "minimum": 0, "maximum": 10 },
        "reaction_writes": { "type": "integer", "minimum": 0 },
        "thread_resolutions": { "type": "integer", "minimum": 0 },
        "worktree_clean": { "type": "boolean" },
        "head_matches": { "type": "boolean" },
        "snapshot_digest_matches": { "type": "boolean" },
        "unexplained_commit": { "type": "boolean" },
        "signatures_valid": { "type": "boolean" },
        "evidence_complete": { "type": "boolean" },
        "ci_state": { "enum": ["SUCCESS", "PENDING", "FAILED", "MISSING"] },
        "unresolved_material_finding": { "type": "boolean" },
        "github_state_safe": { "type": "boolean" },
        "scope_requires_other_repository": { "type": "boolean" },
        "late_feedback_detected": { "type": "boolean" },
        "push_failed": { "type": "boolean" },
        "mutation_failed": { "type": "boolean" },
        "actionable_findings": { "type": "boolean" },
        "merge_ready_evidence": { "type": "boolean" }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "logical_finding_id",
        "source_node_ids",
        "source_database_ids",
        "parent_thread_id",
        "classification",
        "canonical_finding_id",
        "disposition",
        "evidence_digest",
        "test_evidence",
        "commit_sha"
      ],
      "properties": {
        "logical_finding_id": { "type": "string", "minLength": 1 },
        "source_node_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "source_database_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "integer", "minimum": 1 }
        },
        "parent_thread_id": { "$ref": "#/$defs/nullable_string" },
        "classification": { "$ref": "#/$defs/classification" },
        "canonical_finding_id": { "$ref": "#/$defs/nullable_string" },
        "disposition": {
          "enum": [
            "PENDING",
            "CORRECTED_AND_VERIFIED",
            "PROVEN_EXISTING_FIX",
            "DISPROVEN_WITH_EVIDENCE",
            "NON_ACTIONABLE",
            "DUPLICATE_OF_CANONICAL",
            "OBSOLETE_ON_CURRENT_HEAD",
            "SUPERSEDED_BY_CANONICAL",
            "USER_DECISION_REQUIRED",
            "OUT_OF_SCOPE",
            "CROSS_REPOSITORY_BLOCKER",
            "REJECTED_SECURITY_WEAKENING"
          ]
        },
        "evidence_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "test_evidence": { "type": "array", "items": { "type": "string" } },
        "commit_sha": {
          "type": ["string", "null"],
          "pattern": "^[0-9a-fA-F]{40,64}$"
        }
      }
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation_id",
        "logical_finding_id",
        "kind",
        "target_node_id",
        "target_database_id",
        "parent_thread_id",
        "expected_current_state",
        "expected_actor_identity",
        "expected_source_actor_identity",
        "classification",
        "evidence_digest",
        "reaction",
        "reply_body",
        "applied_mutation_identity",
        "resolution_preconditions"
      ],
      "properties": {
        "operation_id": { "type": "string", "minLength": 1 },
        "logical_finding_id": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["REACTION", "EVIDENCE_REPLY", "THREAD_RESOLUTION"] },
        "target_node_id": { "type": "string", "minLength": 1 },
        "target_database_id": { "$ref": "#/$defs/nullable_integer" },
        "parent_thread_id": { "$ref": "#/$defs/nullable_string" },
        "expected_current_state": { "$ref": "#/$defs/expected_current_state" },
        "expected_actor_identity": { "$ref": "#/$defs/actor_identity" },
        "expected_source_actor_identity": { "$ref": "#/$defs/source_actor_identity" },
        "classification": { "$ref": "#/$defs/classification" },
        "evidence_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "reaction": { "enum": ["THUMBS_UP", "THUMBS_DOWN", null] },
        "reply_body": { "$ref": "#/$defs/nullable_string" },
        "applied_mutation_identity": { "$ref": "#/$defs/nullable_string" },
        "resolution_preconditions": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": [
            "pushed",
            "focused_validation_succeeded",
            "complete_validation_succeeded",
            "required_ci_succeeded",
            "valid_signatures",
            "heads_match",
            "worktree_clean",
            "no_late_feedback",
            "all_thread_findings_disposed"
          ],
          "properties": {
            "pushed": { "type": "boolean" },
            "focused_validation_succeeded": { "type": "boolean" },
            "complete_validation_succeeded": { "type": "boolean" },
            "required_ci_succeeded": { "type": "boolean" },
            "valid_signatures": { "type": "boolean" },
            "heads_match": { "type": "boolean" },
            "worktree_clean": { "type": "boolean" },
            "no_late_feedback": { "type": "boolean" },
            "all_thread_findings_disposed": { "type": "boolean" }
          }
        }
      }
    },
    "expected_current_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_type",
        "body_digest",
        "is_resolved",
        "is_outdated",
        "material_misunderstanding",
        "invalidity_non_obvious"
      ],
      "properties": {
        "target_type": {
          "enum": [
            "ISSUE_COMMENT",
            "PULL_REQUEST_REVIEW",
            "PULL_REQUEST_REVIEW_COMMENT",
            "PULL_REQUEST_REVIEW_THREAD"
          ]
        },
        "body_digest": {
          "type": ["string", "null"],
          "pattern": "^[0-9a-f]{64}$"
        },
        "is_resolved": { "type": ["boolean", "null"] },
        "is_outdated": { "type": "boolean" },
        "material_misunderstanding": { "type": "boolean" },
        "invalidity_non_obvious": { "type": "boolean" }
      }
    },
    "actor_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["login", "node_id", "database_id"],
      "properties": {
        "login": { "type": "string", "minLength": 1 },
        "node_id": { "type": "string", "minLength": 1 },
        "database_id": { "type": "integer", "minimum": 1 }
      }
    },
    "source_actor_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["login", "node_id", "database_id"],
      "properties": {
        "login": { "$ref": "#/$defs/nullable_string" },
        "node_id": { "$ref": "#/$defs/nullable_string" },
        "database_id": { "$ref": "#/$defs/nullable_integer" }
      }
    }
  }
}
